{
  "name": "@rodrigo-barraza/utilities-library",
  "version": "0.2.0",
  "description": "Shared TypeScript utility functions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./dist/node.js"
    },
    "./vault": {
      "types": "./src/vault.ts",
      "import": "./dist/vault.js"
    },
    "./mongo": {
      "types": "./src/mongo.ts",
      "import": "./dist/mongo.js"
    },
    "./eslint": {
      "types": "./src/config/eslint.ts",
      "import": "./dist/config/eslint.js"
    },
    "./vitest": {
      "types": "./src/config/vitest.ts",
      "import": "./dist/config/vitest.js"
    },
    "./express": {
      "types": "./src/express.ts",
      "import": "./dist/express.js"
    },
    "./nextjs": {
      "types": "./src/nextjs.ts",
      "import": "./dist/nextjs.js"
    },
    "./taxonomy": {
      "types": "./src/taxonomy.ts",
      "import": "./dist/taxonomy.js"
    },
    "./media": {
      "types": "./src/media.ts",
      "import": "./dist/media.js"
    },
    "./effects": {
      "types": "./src/effects.ts",
      "import": "./dist/effects.js"
    },
    "./rate": {
      "types": "./src/rate.ts",
      "import": "./dist/rate.js"
    },
    "./color": {
      "types": "./src/color.ts",
      "import": "./dist/color.js"
    },
    "./schemas": {
      "types": "./src/schemas.ts",
      "import": "./dist/schemas.js"
    },
    "./testing": {
      "types": "./src/testing.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepare": "[ -d node_modules/typescript ] && tsc || true",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "next": "^16.2.6",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigo-barraza/utilities-library.git"
  },
  "keywords": [
    "utilities",
    "helpers",
    "typescript"
  ],
  "author": "Rodrigo Barraza <hello@rod.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "mongodb": "^7.2.0",
    "zod": "^4.4.3"
  }
}
